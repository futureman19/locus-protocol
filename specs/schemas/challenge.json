{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://locusprotocol.org/schemas/challenge.json",
  "title": "Ghost Challenge Transaction",
  "description": "Schema for Locus Protocol challenge OP_RETURN payload",
  "type": "object",
  "required": ["protocol", "version", "type", "ghost_id", "challenge_id", "challenger", "challenge_type", "evidence_txid", "stake_sats"],
  "properties": {
    "protocol": {
      "type": "string",
      "const": "locus",
      "description": "Protocol identifier"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Protocol version"
    },
    "type": {
      "type": "string",
      "const": "CHALLENGE",
      "description": "Transaction type"
    },
    "ghost_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Challenged ghost identifier"
    },
    "challenge_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique UUID for this challenge"
    },
    "challenger": {
      "type": "string",
      "pattern": "^(1|3|bc1)[a-zA-Z0-9]{25,62}$",
      "description": "BSV address of challenger"
    },
    "challenge_type": {
      "type": "string",
      "enum": ["NO_SHOW", "MALFUNCTION", "LOCATION_FRAUD", "FEE_EVASION"],
      "description": "Type of challenge"
    },
    "evidence_txid": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Transaction ID of referenced evidence"
    },
    "stake_sats": {
      "type": "integer",
      "minimum": 10000,
      "description": "Challenger stake amount (min 10,000 sats)"
    },
    "description_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "SHA-256 hash of detailed challenge description"
    },
    "proposed_resolution": {
      "type": "string",
      "enum": ["WARNING", "SLASH_PARTIAL", "SLASH_FULL"],
      "description": "Proposed penalty if challenge upheld"
    }
  },
  "additionalProperties": false
}
